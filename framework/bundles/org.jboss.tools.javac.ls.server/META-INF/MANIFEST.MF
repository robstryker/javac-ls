Manifest-Version: 1.0
Bundle-ManifestVersion: 2
Bundle-Name: org.jboss.tools.javac.ls.server
Bundle-SymbolicName: org.jboss.tools.javac.ls.server
Automatic-Module-Name: org.jboss.tools.javac.ls.server
Bundle-Version: 0.0.1.qualifier
Bundle-RequiredExecutionEnvironment: JavaSE-1.8
Bundle-Activator: org.jboss.tools.javac.ls.server.ServerCoreActivator
