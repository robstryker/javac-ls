Manifest-Version: 1.0
Bundle-ManifestVersion: 2
Bundle-Name: Javac-LS Parser
Bundle-SymbolicName: org.jboss.tools.javac.ls.parser
Automatic-Module-Name: org.jboss.tools.javac.ls.parser
Bundle-Version: 0.0.1.qualifier
Bundle-RequiredExecutionEnvironment: JavaSE-17
Bundle-ClassPath: .,
 lib/nb-javac-shaded-jdk-26-35.jar,
 lib/nb-javac-api-shaded-jdk-26-35.jar,
 lib/nnb-doclint-shaded-jdk-26-35-patch2.jar
Require-Bundle: org.jboss.tools.jdt.core.dom
Import-Package: org.eclipse.jdt.core,
 org.eclipse.jdt.internal.compiler.impl,
 org.slf4j;version="1.7.10"
Export-Package: org.eclipse.jdt.internal.core.dom.cache,
 org.eclipse.jdt.internal.core.dom.javac,
 org.eclipse.jdt.internal.javac.problem,
 shaded.com.sun.source.doctree,
 shaded.com.sun.source.tree,
 shaded.com.sun.source.util,
 shaded.com.sun.tools.doclint,
 shaded.com.sun.tools.javac.api,
 shaded.com.sun.tools.javac.code,
 shaded.com.sun.tools.javac.comp,
 shaded.com.sun.tools.javac.file,
 shaded.com.sun.tools.javac.main,
 shaded.com.sun.tools.javac.parser,
 shaded.com.sun.tools.javac.tree,
